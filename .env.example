BRIDGE_DATABASE_PATH=data/bridge.db
BRIDGE_ARTIFACTS_DIR=artifacts
BRIDGE_LOGS_DIR=logs
BRIDGE_CODEX_COMMAND=codex
BRIDGE_WORKER_POLL_INTERVAL_SECONDS=2
BRIDGE_DEFAULT_WORK_DIR=data/demo_workspace
# Multi-root config takes precedence over BRIDGE_ALLOWED_WORK_ROOT when set.
# BRIDGE_ALLOWED_WORK_ROOTS=data/demo_workspace,/absolute/path/to/project_b
# BRIDGE_ALLOWED_WORK_ROOTS=["data/demo_workspace", "/absolute/path/to/project_b"]
# CODEX_BRIDGE_ALLOWED_WORK_ROOTS=["data/demo_workspace", "/absolute/path/to/project_b"]
BRIDGE_ALLOWED_WORK_ROOT=data/demo_workspace
# CODEX_BRIDGE_ALLOWED_WORK_ROOT=data/demo_workspace
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8000
BRIDGE_MCP_HOST=127.0.0.1
BRIDGE_MCP_PORT=8001
BRIDGE_MCP_PATH=/mcp
# If your MCP server is exposed publicly, set this to the public origin, e.g. https://abc.ngrok-free.app
BRIDGE_MCP_PUBLIC_BASE_URL=
BRIDGE_MCP_AUTH_ENABLED=false
# Example: https://your-tenant.us.auth0.com/
BRIDGE_MCP_AUTH_ISSUER_URL=
# Example: https://codex-bridge-mcp
BRIDGE_MCP_AUTH_AUDIENCE=
BRIDGE_MCP_AUTH_REQUIRED_SCOPES=mcp:use
BRIDGE_EMBED_WORKER=false
# BRIDGE_TUNNEL_COMMAND=ngrok http 8001
